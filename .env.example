# Public base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://aiforacademic.world

# The actual WordPress origin server — used by next.config.ts rewrites
# Set this in Vercel to the origin server that runs WordPress PHP.
# If WordPress is on the same host (e.g. Hostinger/cPanel) and aiforacademic.world
# points there by default, you may leave this blank or set it to the same domain.
WORDPRESS_ORIGIN=https://aiforacademic.world
