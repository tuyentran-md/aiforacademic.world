rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth helper
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    
    function resourceMatchesUser() {
      return request.auth != null && resource.data.userId == request.auth.uid;
    }
    
    function requestMatchesUser() {
      return request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Projects
    match /projects/{projectId} {
      allow read, delete: if resourceMatchesUser();
      allow create: if requestMatchesUser();
      allow update: if resourceMatchesUser() && requestMatchesUser();
    }

    // Artifacts
    match /artifacts/{artifactId} {
      allow read, delete: if resourceMatchesUser();
      allow create: if requestMatchesUser();
      allow update: if resourceMatchesUser() && requestMatchesUser();
    }

    // Messages
    match /messages/{messageId} {
      allow read, delete: if resourceMatchesUser();
      allow create: if requestMatchesUser();
      allow update: if resourceMatchesUser() && requestMatchesUser();
    }

    // Orders (SePay)
    match /orders/{orderId} {
      allow read: if isOwner(resource.data.uid);
      allow create, update, delete: if false; // Admin SDK only
    }

    // Usage limits (users subcollection)
    match /users/{userId}/usage/{usageId} {
      allow read: if isOwner(userId);
      allow write: if false; // Only Admin SDK can track usage
    }
    
    // Legacy Anon Usage
    match /anon_usage/{docId} {
      allow read, write: if false; // Only Admin SDK
    }

    // Profile schema
    match /profile/{userId} {
      // Allow read if accessing own profile
      allow read: if isOwner(userId);
      // Let standard API handle 'create' gracefully when using Admin SDK webhook
      // Write logic is mostly locked down to server-side Webhook (Admin SDK bypasses this entirely)
      // Exception: Frontend calls getOrCreateProfile, meaning frontend MUST create it!
      // To satisfy P0 specs "write via Admin SDK only" alongside initial creation:
      allow create: if isOwner(userId);
      allow update, delete: if false; // Admin SDK only for quota updates and billing syncs
    }

    // Legacy sessions (deprecated)
    match /sessions/{sessionId} {
      // Kept around for Migration script (it's client side so it needs read/write)
      allow read, write: if request.auth != null && (resource == null || resource.data.ownerUid == request.auth.uid || request.resource.data.ownerUid == request.auth.uid);
    }
  }
}
